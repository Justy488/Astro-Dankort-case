---
const currentPath = Astro.url.pathname;
---

<header>
  <a href="/index" class="logo">
    <img src="/pictures/dankortlogo.svg" alt="Dankort logo" />
  </a>

  <nav id="navMenu">
    <ul class="menu">
      <li>
        <a href="/naturfonden" class={currentPath === "/naturfonden" ? "active" : ""} data-da="Naturfonden" data-en="Nature Fund"> Naturfonden </a>
      </li>
      <li>
        <a href="/benefits" class={currentPath === "/benefits" ? "active" : ""} data-da="Fordele" data-en="Benefits"> Fordele </a>
      </li>
      <li>
        <a href="/" class={currentPath === "/" ? "active" : ""} data-da="Hjem" data-en="Home"> Hjem </a>
      </li>
    </ul>
  </nav>

  <div class="header-actions">
    <div class="language-dropdown">
      <button class="language-current" id="languageToggle" type="button">
        <img id="currentFlag" src="/pictures/danishflagg.png" alt="Dansk flag" />
      </button>

      <div class="language-menu" id="languageMenu">
        <button type="button" class="language-option" data-lang="da">
          <img src="/pictures/danishflagg.png" alt="Dansk flag" />
          <span>Dansk</span>
        </button>

        <button type="button" class="language-option" data-lang="en">
          <img src="/pictures/englishflag.png" alt="English flag" />
          <span>English</span>
        </button>
      </div>
    </div>

    <button class="burger" id="burgerBtn" type="button" aria-label="Open menu">
      <span class="line"></span>
      <span class="line"></span>
      <span class="line"></span>
    </button>
  </div>
</header>

<script>
  const burger = document.querySelector("#burgerBtn");
  const nav = document.querySelector("#navMenu");

  burger?.addEventListener("click", () => {
    burger.classList.toggle("active");
    nav?.classList.toggle("active");
  });
</script>
