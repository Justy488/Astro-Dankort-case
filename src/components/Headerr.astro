<header>
  <style>
    body {
      padding-top: 80px;
    }
  </style>

  <a href="/" class="logo">
    <img src="/pictures/dankortlogo.svg" alt="Dankort logo" />
  </a>

  <nav>
    <a href="/naturfonden" data-da="Naturfonden" data-en="Nature Fund">Naturfonden</a>
    <a href="/fordele" data-da="Fordele" data-en="Benefits">Fordele</a>
    <a href="/index" data-da="Hjem" data-en="Home">Hjem</a>

    <div class="language-dropdown">
      <button class="language-current" id="languageToggle" type="button">
        <img id="currentFlag" src="/pictures/danishflagg.png" alt="Dansk flag" />
      </button>

      <div class="language-menu" id="languageMenu">
        <button type="button" class="language-option" data-lang="da">
          <img src="/pictures/danishflagg.png" alt="Dansk flag" />
          <span>Dansk</span>
        </button>

        <button type="button" class="language-option" data-lang="en">
          <img src="/pictures/englishflag.png" alt="English flag" />
          <span>English</span>
        </button>
      </div>
    </div>
  </nav>
</header>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2.5rem;
    background: transparent;
  }
  .logo img {
    height: 48px;
    width: auto;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  nav a {
    color: rgb(0, 0, 0);
    text-decoration: none;
    font-size: 16px;
  }

  nav a:hover {
    text-decoration: underline;
    color: #bac89e;
  }

  .flag {
    height: 36px;
    object-fit: cover;
  }
  .language-dropdown {
    position: relative;
    display: inline-block;
  }

  .language-current {
    border: none;
    background: transparent;
    padding: 0;
    cursor: pointer;
  }

  .language-current img {
    height: 36px;
    object-fit: cover;
    display: block;
  }

  .language-menu {
    display: none;
    position: absolute;
    top: 48px;
    right: 0;
    min-width: 150px;
    background: white;
    border-radius: 16px;
    padding: 8px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.16);
    z-index: 200;
  }

  .language-menu.open {
    display: block;
  }

  .language-option {
    width: 100%;
    border: none;
    background: transparent;
    padding: 10px 12px;
    border-radius: 12px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    text-align: left;
  }

  .language-option img {
    height: 24px;
    object-fit: cover;
  }

  .language-option:hover {
    background-color: #f2eee6;
  }
</style>
