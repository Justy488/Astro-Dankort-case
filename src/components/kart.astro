---
import { supabase } from "../supabase.js";
import svgContent from "../../public/pictures/dot.svg?raw";
import "../Style/kart.css";

const { data: omraader, error } = await supabase
  .from("naturfonden")
  .select("*");

if (error) {
  console.error("Fejl ved hentning af data:", error.message);
}
---

<div class="map-container">
  <video class="baggrunds-video" autoplay muted loop playsinline>
    <source src="/pictures/videonaturfonden.mp4" type="video/mp4" />
  </video>
  <div class="hero-tekst">
    <h1>Naturfonden</h1>
    <p class="lille-tekst">
      Trykk deg inn på karte for at se hvilke områder du er med på at redde
    </p>
  </div>

  <div class="map">
    <Fragment set:html={svgContent} />
  </div>

  <div class="info-box hidden" id="info-box">
    <div class="billede-wrap">
      <img id="info-image" src="" alt="Område" hidden />
      <div class="billede-tekst">
        <h2 id="info-title"></h2>
        <p id="info-region"></p>
      </div>
    </div>
    <p id="info-description"></p>
    <a id="info-link" href="#" class="btn">Læs mere</a>
  </div>

  <script define:vars={{ omraader }}>
    const alleDots = document.querySelectorAll('[id^="dot"]');

    function visOmraade(dot) {
      const match = omraader?.find((o) => o.dot_id === dot.id);
      if (!match) return;

      alleDots.forEach((d) => d.classList.remove("aktiv"));
      dot.classList.add("aktiv");
      document.getElementById("info-title").textContent = match.titel;
      document.getElementById("info-region").textContent = match.region;
      document.getElementById("info-description").textContent =
        match.informasjon;

      const image = document.getElementById("info-image");
      if (match.image_url) {
        image.src = match.image_url;
        image.hidden = false;
      } else {
        image.hidden = true;
      }

      document.getElementById("info-link").href =
        match.link_url ?? `/natur/${match.slug}`;
      document.getElementById("info-box").classList.remove("hidden");
    }

    alleDots.forEach((dot) => {
      dot.style.cursor = "pointer";
      dot.addEventListener("click", () => visOmraade(dot));
    });
    const startDot = document.getElementById("dot1");
    if (startDot) visOmraade(startDot);
  </script>
</div>
